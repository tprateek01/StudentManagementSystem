@model StudentManagementSystem.Models.Student

<div class="container mt-4 mb-5" style="max-width: 650px;">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white text-center py-3">
            <h3 class="mb-0 fw-bold">Student Registration</h3>
        </div>
        <div class="card-body p-4">
            @using (Html.BeginForm("Register", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <!-- Personal Details Section -->
                <h5 class="text-secondary border-bottom pb-2 mb-3 fw-bold">Personal Information</h5>

                <div class="mb-3">
                    <label class="form-label fw-bold">Full Name</label>
                    @Html.TextBoxFor(m => m.Name, new { @class = "form-control", required = "required", placeholder = "Enter full name" })
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Date of Birth</label>
                        @Html.TextBoxFor(m => m.DOB, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date", required = "required" })
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Hometown</label>
                        @Html.TextBoxFor(m => m.Hometown, new { @class = "form-control", required = "required", placeholder = "e.g., Delhi" })
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mobile Number</label>
                    @Html.TextBoxFor(m => m.Mobile, new { @class = "form-control", placeholder = "Enter 10-digit mobile number", required = "required" })
                    <small class="text-muted d-block mt-1">Must be a valid 10-digit Indian mobile number (only numbers allowed).</small>
                </div>

                <!-- Academic Parameters Section -->
                <h5 class="text-secondary border-bottom pb-2 mt-4 mb-3 fw-bold">Academic Matrix</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Course Branch</label>
                        @Html.TextBoxFor(m => m.Course, new { @class = "form-control", placeholder = "e.g., B.Tech CSE", required = "required" })
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Current Semester</label>
                        @Html.TextBoxFor(m => m.Semester, new { @class = "form-control", type = "number", min = "1", max = "8", required = "required", placeholder = "e.g., 8" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">CGPA</label>
                        @Html.TextBoxFor(m => m.CGPA, new { @class = "form-control", type = "number", step = "0.01", min = "0", max = "10", placeholder = "0.00" })
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">SGPA</label>
                        @Html.TextBoxFor(m => m.SGPA, new { @class = "form-control", type = "number", step = "0.01", min = "0", max = "10", placeholder = "0.00" })
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Department Link</label>
                    @Html.DropDownListFor(m => m.DepartmentId, (SelectList)ViewBag.Departments, "Select Department", new { @class = "form-select", required = "required" })
                </div>

                <!-- Credentials Section -->
                <h5 class="text-secondary border-bottom pb-2 mt-4 mb-3 fw-bold">Account Credentials</h5>

                <div class="mb-3">
                    <label class="form-label fw-bold">Username</label>
                    @Html.TextBoxFor(m => m.Username, new { @class = "form-control", required = "required", placeholder = "Choose a unique username" })
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Password</label>
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", required = "required", placeholder = "Enter strong password" })
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Confirm Password</label>
                        <input type="password" name="ConfirmPassword" class="form-control" required placeholder="Re-enter password" />
                    </div>
                </div>

                <div class="text-muted small bg-light p-3 rounded mb-4 border">
                    <strong class="d-block mb-1 text-dark">Password Requirements:</strong>
                    <ul class="mb-0 ps-3">
                        <li>Minimum 8 characters</li>
                        <li>At least one uppercase and one lowercase letter</li>
                        <li>At least one number and one special character</li>
                    </ul>
                </div>

                <button type="submit" class="btn btn-success w-100 py-2 fw-bold shadow-sm">Register</button>

                <div class="text-center mt-3">
                    <a href="@Url.Action("Login", "Account")" class="text-decoration-none">Already have an account? Login here</a>
                </div>
            }
        </div>
    </div>
</div>
@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">
    <div class="p-5 mb-4 bg-light rounded-3 border shadow-sm">
        <div class="container-fluid py-5 text-center">
            <h1 class="display-4 fw-bold text-dark">Student Data Management Portal</h1>
            <p class="col-md-8 mx-auto fs-5 text-muted mt-3">
                Welcome to the unified educational data management system. Designed for seamless monitoring of academic profiles, departmental metrics, and administrative governance records.
            </p>
            <hr class="my-4" style="max-width: 400px; margin: 0 auto;">
            <div class="d-flex justify-content-center gap-3 mt-4">
                <a href="@Url.Action("Login", "Account")" class="btn btn-primary btn-lg px-4 shadow">Account Portal Secure Sign In</a>
                <a href="@Url.Action("Register", "Account")" class="btn btn-outline-secondary btn-lg px-4">New Student Enrollment</a>
            </div>
        </div>
    </div>

    <div class="row align-items-stretch g-4 mt-2">
        <div class="col-md-6">
            <div class="h-100 p-4 border rounded-3 bg-white shadow-sm">
                <h3 class="text-primary"><i class="bi bi-shield-lock"></i> Administrative Governance</h3>
                <p class="text-muted">Authorized administrative staff can review macro performance metrics, adjust student indices, execute full database CRUD management tracking, and filter profiles by structural metrics.</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="h-100 p-4 border rounded-3 bg-white shadow-sm">
                <h3 class="text-success"><i class="bi bi-person-badge"></i> Student Profiles</h3>
                <p class="text-muted">Enrolled accounts gain interactive dashboard cards to log continuous performance records, view read-only baseline indicators, and modify active semester paths.</p>
            </div>
        </div>
    </div>
</div>
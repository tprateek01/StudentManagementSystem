@model StudentManagementSystem.Models.Student

<div class="container mt-5" style="max-width: 600px;">
    <div class="card shadow border-0">
        <div class="card-header bg-warning text-dark text-center py-3">
            <h4 class="mb-0 fw-bold">Modify Student Parameters</h4>
        </div>
        <div class="card-body p-4">
            <form method="post" action="@Url.Action("EditStudent", "Admin")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Full Name</label>
                    <input type="text" name="Name" value="@Model.Name" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Username</label>
                    <input type="text" name="Username" value="@Model.Username" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Department</label>
                    @Html.DropDownListFor(m => m.DepartmentId, (SelectList)ViewBag.Departments, "Select Department", new { @class = "form-select", required = "required" })
                </div>
                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label fw-bold">CGPA</label>
                        <input type="number" name="CGPA" value="@Model.CGPA" step="0.01" class="form-control" />
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label fw-bold">SGPA</label>
                        <input type="number" name="SGPA" value="@Model.SGPA" step="0.01" class="form-control" />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-success flex-grow-1 py-2 fw-bold shadow-sm">Save Structural Updates</button>
                    <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-secondary py-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@model IEnumerable<StudentManagementSystem.Models.Student>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold">Registered Administrative Officers</h2>
        <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    <div class="card shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>System ID</th>
                    <th>Full Name</th>
                    <th>Username Index</th>
                    <th>Role Clearance</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var admin in Model)
                {
                    <tr>
                        <td>@admin.Id</td>
                        <td class="fw-bold text-primary">@admin.Name</td>
                        <td>@admin.Username</td>
                        <td><span class="badge bg-danger">@admin.Role</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>